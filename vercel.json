{
  "rewrites": [
    {
      "source": "/download/:branch/latest",
      "destination": "/api/download?branch=:branch&target=latest"
    },
    {
      "source": "/download/:branch/:fileName",
      "destination": "/api/download?branch=:branch&target=:fileName"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
